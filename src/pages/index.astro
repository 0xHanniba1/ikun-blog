---
import { execSync } from "node:child_process";
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getUniqueTags from "@/utils/getUniqueTags";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const tags = getUniqueTags(posts);

const totalPosts = sortedPosts.length;
const totalTags = tags.length;

// ── Words & reading time (markdown body) ───────────────────────────
function countBody(md: string): { words: number; minutes: number } {
  const cleaned = md
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/[#>*_~`>\-]/g, " ");
  const cjk = (cleaned.match(/[一-鿿]/g) || []).length;
  const eng = (cleaned.match(/[A-Za-z][A-Za-z'-]*/g) || []).length;
  return { words: cjk + eng, minutes: cjk / 300 + eng / 200 };
}

let totalWords = 0;
let totalMinutes = 0;
for (const p of sortedPosts) {
  const body = (p as unknown as { body?: string }).body ?? "";
  const { words, minutes } = countBody(body);
  totalWords += words;
  totalMinutes += minutes;
}
const wordsStr =
  totalWords >= 1000 ? `${(totalWords / 1000).toFixed(1)}k` : String(totalWords);
const readingHint =
  totalMinutes >= 60
    ? `约 ${(totalMinutes / 60).toFixed(1)} 小时阅读`
    : `约 ${Math.max(1, Math.round(totalMinutes))} 分钟阅读`;

// ── Git stats (build-time) ─────────────────────────────────────────
function safeGit(cmd: string): string {
  try {
    return execSync(`git ${cmd}`, { encoding: "utf8" }).trim();
  } catch {
    return "";
  }
}
const totalCommitsRaw = safeGit("rev-list --count HEAD");
const totalCommitsNum = parseInt(totalCommitsRaw || "0", 10);
const totalCommitsStr = totalCommitsNum > 0
  ? totalCommitsNum.toLocaleString("en-US")
  : "—";
const recent7Raw = safeGit('log --since="7 days ago" --oneline');
const recent7 = recent7Raw ? recent7Raw.split("\n").filter(Boolean).length : 0;

// ── "Since" — earliest post date ──────────────────────────────────
const earliest = sortedPosts.length
  ? dayjs(
      sortedPosts.reduce<Date>(
        (min, p) => (p.data.pubDatetime < min ? p.data.pubDatetime : min),
        sortedPosts[0]!.data.pubDatetime
      )
    )
  : dayjs();
const sinceStr = earliest.format("YYYY-MM-DD");
const today = dayjs().tz(SITE.timezone);
const ageDays = today.diff(earliest, "day");
const ageYears = Math.floor(ageDays / 365);
const ageRest = ageDays - ageYears * 365;
const uptimeStr = ageYears > 0 ? `${ageYears}y ${ageRest}d` : `${ageDays}d`;

const stats = [
  {
    cmd: "wc -l ./posts/*.md",
    value: String(totalPosts),
    unit: "posts",
    hint: `/ ${totalTags} 个标签`,
  },
  {
    cmd: "cat ./posts/*.md | wc -w",
    value: wordsStr,
    unit: "words",
    hint: readingHint,
  },
  {
    cmd: "git log --oneline | wc -l",
    value: totalCommitsStr,
    unit: "commits",
    hint: recent7 > 0 ? `最近 7 天 +${recent7}` : "稳定运行中",
  },
  {
    cmd: "uptime",
    value: uptimeStr,
    unit: "uptime",
    hint: `自 ${sinceStr}`,
  },
];

const timeline = sortedPosts.slice(0, 10);
const updatedToday = today.format("YYYY-MM-DD HH:mm");
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout pt-7 pb-10">
    <!-- Hero ──────────────────────────────────────────────── -->
    <section class="pb-6">
      <div
        class="font-mono text-[12.5px]"
        style="color: color-mix(in srgb, var(--foreground) 65%, transparent);"
      >
        <span class="term-prompt">han@ikun126</span><span style="color: var(--muted);"
          >:~$</span
        > whoami
      </div>
      <h1
        class="term-cn font-extrabold mt-3 mb-1.5 text-[34px] sm:text-[42px] leading-[1.15] tracking-tight"
      >
        {SITE.title}<span class="term-cursor"></span>
      </h1>
      <div
        class="font-mono text-[13px] mb-4"
        style="color: var(--muted);"
      >
        // han@ikun126:~$ cat about.md
      </div>
      <p
        class="term-cn text-[15px] leading-[1.85] max-w-[600px] m-0"
      >
        {SITE.desc}
      </p>
      <p
        class="font-mono text-[13px] mt-1.5"
        style="color: color-mix(in srgb, var(--foreground) 65%, transparent);"
      >
        # 慢就是快 / 自律 / 坚持。
      </p>

      <div class="font-mono text-[12.5px] flex flex-wrap gap-x-3 gap-y-1 mt-5">
        <span style="color: var(--muted);">links:</span>
        <a class="term-link" href="https://github.com/0xhanniba1" target="_blank"
          rel="noopener">github</a>
        <a class="term-link" href="https://x.com/0xHanniba1" target="_blank"
          rel="noopener">x.com</a>
        <a class="term-link" href="/rss.xml">rss.xml</a>
      </div>
    </section>

    <!-- Stats card ─────────────────────────────────────────── -->
    <section class="pt-2 pb-8">
      <div
        class="font-mono text-[12.5px] mb-2.5"
        style="color: color-mix(in srgb, var(--foreground) 70%, transparent);"
      >
        <span class="term-prompt">han@ikun126</span><span style="color: var(--muted);"
          >:~$</span
        > ./scripts/stats.sh
        <span class="term-comment">// auto-generated · {updatedToday}</span>
      </div>
      <div
        class="rounded-sm px-4 py-3 sm:px-5 sm:py-4"
        style="border: 1px dashed var(--border);"
      >
        {
          stats.map(s => (
            <div class="font-mono text-[12.5px] leading-[1.95] flex items-baseline gap-3 flex-wrap">
              <span
                class="truncate"
                style="opacity: 0.5; flex: 0 0 auto; min-width: 200px;"
              >
                $ {s.cmd}
              </span>
              <span
                class="font-semibold text-[14px]"
                style="color: var(--accent);"
              >
                {s.value}
              </span>
              <span style="opacity: 0.6;">{s.unit}</span>
              <span
                class="term-cn ms-auto text-[12px]"
                style="color: var(--muted);"
              >
                # {s.hint}
              </span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Timeline (recent posts) ────────────────────────────── -->
    <section class="pb-10">
      <div
        class="font-mono text-[12.5px] mb-3 flex items-baseline gap-2"
        style="color: color-mix(in srgb, var(--foreground) 70%, transparent);"
      >
        <span>
          <span class="term-prompt">han@ikun126</span><span
            style="color: var(--muted);">:~$</span
          > tail -n {timeline.length} timeline.log
        </span>
        <span class="flex-1"></span>
        <a class="term-link text-[11.5px]" href="/posts/">view all →</a>
      </div>

      <div class="relative">
        <div
          class="absolute top-2 bottom-2 w-px"
          style="left: 104px; background: var(--border); opacity: 0.55;"
          aria-hidden="true"
        >
        </div>
        <ul class="m-0 p-0 list-none">
          {
            timeline.map(p => {
              const date = dayjs(p.data.pubDatetime)
                .tz(SITE.timezone)
                .format("MM-DD");
              return (
                <li>
                  <a
                    class="term-card flex items-start gap-0 px-2 py-2.5 no-underline"
                    href={getPath(p.id, p.filePath)}
                  >
                    <span
                      class="font-mono text-[12px] tabular-nums text-right"
                      style="width: 96px; flex-shrink: 0; padding-right: 8px; padding-top: 2px; color: var(--muted);"
                    >
                      {date}
                    </span>
                    <span
                      class="text-[14px] text-center leading-[20px]"
                      style="width: 16px; flex-shrink: 0; color: var(--accent);"
                      aria-hidden="true"
                    >
                      ●
                    </span>
                    <div class="flex-1 min-w-0" style="padding-left: 14px;">
                      <div class="term-cn term-card-title text-[14.5px] font-semibold leading-snug transition-colors">
                        <span
                          class="font-mono text-[11px] mr-2"
                          style="color: var(--accent);"
                        >
                          POST
                        </span>
                        {p.data.title}
                      </div>
                      {p.data.description && (
                        <div
                          class="term-cn text-[13px] mt-1 leading-[1.6]"
                          style="color: color-mix(in srgb, var(--foreground) 65%, transparent);"
                        >
                          {p.data.description}
                        </div>
                      )}
                    </div>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
