---
import { execSync } from "node:child_process";
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getUniqueTags from "@/utils/getUniqueTags";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconBrandX from "@/assets/icons/IconBrandX.svg";
import IconRss from "@/assets/icons/IconRss.svg";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const tags = getUniqueTags(posts);

const totalPosts = sortedPosts.length;
const totalTags = tags.length;

// ── Words & reading time (markdown body) ───────────────────────────
function countBody(md: string): { words: number; minutes: number } {
  const cleaned = md
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/[#>*_~`>\-]/g, " ");
  const cjk = (cleaned.match(/[一-鿿]/g) || []).length;
  const eng = (cleaned.match(/[A-Za-z][A-Za-z'-]*/g) || []).length;
  return { words: cjk + eng, minutes: cjk / 300 + eng / 200 };
}

let totalWords = 0;
let totalMinutes = 0;
for (const p of sortedPosts) {
  const body = (p as unknown as { body?: string }).body ?? "";
  const { words, minutes } = countBody(body);
  totalWords += words;
  totalMinutes += minutes;
}
const wordsStr =
  totalWords >= 1000
    ? `${(totalWords / 1000).toFixed(1)}k`
    : String(totalWords);
const readingHint =
  totalMinutes >= 60
    ? `约 ${(totalMinutes / 60).toFixed(1)} 小时阅读`
    : `约 ${Math.max(1, Math.round(totalMinutes))} 分钟阅读`;

// ── Git stats (build-time) ─────────────────────────────────────────
function safeGit(cmd: string): string {
  try {
    return execSync(`git ${cmd}`, { encoding: "utf8" }).trim();
  } catch {
    return "";
  }
}
const totalCommitsRaw = safeGit("rev-list --count HEAD");
const totalCommitsNum = parseInt(totalCommitsRaw || "0", 10);
const totalCommitsStr =
  totalCommitsNum > 0 ? totalCommitsNum.toLocaleString("en-US") : "—";
const recent7Raw = safeGit('log --since="7 days ago" --oneline');
const recent7 = recent7Raw ? recent7Raw.split("\n").filter(Boolean).length : 0;

// ── "Since" — earliest post date ──────────────────────────────────
const earliest = sortedPosts.length
  ? dayjs(
      sortedPosts.reduce<Date>(
        (min, p) => (p.data.pubDatetime < min ? p.data.pubDatetime : min),
        sortedPosts[0]!.data.pubDatetime
      )
    )
  : dayjs();
const sinceStr = earliest.format("YYYY-MM-DD");
const today = dayjs().tz(SITE.timezone);
const ageDays = today.diff(earliest, "day");
const ageYears = Math.floor(ageDays / 365);
const ageRest = ageDays - ageYears * 365;
const uptimeStr = ageYears > 0 ? `${ageYears}y ${ageRest}d` : `${ageDays}d`;

const stats = [
  {
    cmd: "wc -l ./posts/*.md",
    value: String(totalPosts),
    unit: "posts",
    hint: `/ ${totalTags} 个标签`,
  },
  {
    cmd: "cat ./posts/*.md | wc -w",
    value: wordsStr,
    unit: "words",
    hint: readingHint,
  },
  {
    cmd: "git log --oneline | wc -l",
    value: totalCommitsStr,
    unit: "commits",
    hint: recent7 > 0 ? `最近 7 天 +${recent7}` : "稳定运行中",
  },
  {
    cmd: "uptime",
    value: uptimeStr,
    unit: "uptime",
    hint: `自 ${sinceStr}`,
  },
];

const timeline = sortedPosts.slice(0, 10);
const updatedToday = today.format("YYYY-MM-DD HH:mm");
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout pt-7 pb-10">
    <!-- Hero ──────────────────────────────────────────────── -->
    <section class="pb-6">
      <div
        class="font-mono text-[12.5px]"
        style="color: color-mix(in srgb, var(--foreground) 65%, transparent);"
      >
        <span class="term-prompt">han@ikun126</span><span
          style="color: var(--muted);">:~$</span
        > whoami
      </div>
      <h1
        class="mt-3 mb-5 term-cn text-[34px] leading-[1.15] font-extrabold tracking-tight sm:text-[42px]"
      >
        {SITE.title}<span class="term-cursor"></span>
      </h1>

      <div
        class="mb-3 font-mono text-[12.5px]"
        style="color: color-mix(in srgb, var(--foreground) 70%, transparent);"
      >
        <span class="term-prompt">han@ikun126</span><span
          style="color: var(--muted);">:~$</span
        > cat about.md
      </div>

      <div class="home-about" aria-label="profile">
        <div class="home-about-avatar" aria-hidden="true">
          <span>韩</span>
        </div>
        <div class="home-about-meta">
          <div class="home-about-handle">@0XHANNIBA1</div>
          <div class="home-about-motto term-cn">
            慢就是快<span class="home-about-dot">·</span>自律<span
              class="home-about-dot">·</span
            >坚持
          </div>
          <div class="home-about-socials">
            <a
              href="https://github.com/0xhanniba1"
              target="_blank"
              rel="noopener noreferrer"
              class="home-about-pill"
            >
              <IconGitHub
                class="size-3.5 fill-transparent stroke-current stroke-2"
              />
              <span>0xHanniba1</span>
            </a>
            <a
              href="https://x.com/0xHanniba1"
              target="_blank"
              rel="noopener noreferrer"
              class="home-about-pill"
            >
              <IconBrandX
                class="size-3.5 fill-transparent stroke-current stroke-2"
              />
              <span>@0xHanniba1</span>
            </a>
            <a href="/rss.xml" class="home-about-pill">
              <IconRss
                class="size-3.5 fill-transparent stroke-current stroke-2"
              />
              <span>RSS</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats card ─────────────────────────────────────────── -->
    <section class="pt-2 pb-8">
      <div
        class="mb-2.5 font-mono text-[12.5px]"
        style="color: color-mix(in srgb, var(--foreground) 70%, transparent);"
      >
        <span class="term-prompt">han@ikun126</span><span
          style="color: var(--muted);">:~$</span
        > ./scripts/stats.sh
        <span class="term-comment">// auto-generated · {updatedToday}</span>
      </div>
      <div
        class="rounded-sm px-4 py-3 sm:px-5 sm:py-4"
        style="border: 1px dashed var(--border);"
      >
        {
          stats.map(s => (
            <div class="flex flex-wrap items-baseline gap-3 font-mono text-[12.5px] leading-[1.95]">
              <span
                class="truncate"
                style="opacity: 0.5; flex: 0 0 auto; min-width: 200px;"
              >
                $ {s.cmd}
              </span>
              <span
                class="text-[14px] font-semibold"
                style="color: var(--accent);"
              >
                {s.value}
              </span>
              <span style="opacity: 0.6;">{s.unit}</span>
              <span
                class="ms-auto term-cn text-[12px]"
                style="color: var(--muted);"
              >
                # {s.hint}
              </span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Timeline (recent posts) ────────────────────────────── -->
    <section class="pb-10">
      <div
        class="mb-3 flex items-baseline gap-2 font-mono text-[12.5px]"
        style="color: color-mix(in srgb, var(--foreground) 70%, transparent);"
      >
        <span>
          <span class="term-prompt">han@ikun126</span><span
            style="color: var(--muted);">:~$</span
          > tail -n {timeline.length} timeline.log
        </span>
        <span class="flex-1"></span>
        <a class="term-link text-[11.5px]" href="/posts/">view all →</a>
      </div>

      <div class="relative">
        <div
          class="absolute top-2 bottom-2 w-px"
          style="left: 104px; background: var(--border); opacity: 0.55;"
          aria-hidden="true"
        >
        </div>
        <ul class="m-0 list-none p-0">
          {
            timeline.map(p => {
              const date = dayjs(p.data.pubDatetime)
                .tz(SITE.timezone)
                .format("MM-DD");
              return (
                <li>
                  <a
                    class="term-card flex items-start gap-0 px-2 py-2.5 no-underline"
                    href={getPath(p.id, p.filePath)}
                  >
                    <span
                      class="text-right font-mono text-[12px] tabular-nums"
                      style="width: 96px; flex-shrink: 0; padding-right: 8px; padding-top: 2px; color: var(--muted);"
                    >
                      {date}
                    </span>
                    <span
                      class="text-center text-[14px] leading-[20px]"
                      style="width: 16px; flex-shrink: 0; color: var(--accent);"
                      aria-hidden="true"
                    >
                      ●
                    </span>
                    <div class="min-w-0 flex-1" style="padding-left: 14px;">
                      <div class="term-card-title term-cn text-[14.5px] leading-snug font-semibold transition-colors">
                        <span
                          class="mr-2 font-mono text-[11px]"
                          style="color: var(--accent);"
                        >
                          POST
                        </span>
                        {p.data.title}
                      </div>
                      {p.data.description && (
                        <div
                          class="mt-1 term-cn text-[13px] leading-[1.6]"
                          style="color: color-mix(in srgb, var(--foreground) 65%, transparent);"
                        >
                          {p.data.description}
                        </div>
                      )}
                    </div>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .home-about {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 20px 22px;
    border: 1px dashed var(--border);
    border-radius: 6px;
    background: var(--background);
  }
  @media (max-width: 640px) {
    .home-about {
      flex-direction: column;
      align-items: center;
      gap: 16px;
      padding: 18px 16px;
      text-align: center;
    }
  }

  .home-about-avatar {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--accent) 92%, white 8%) 0%,
      color-mix(in srgb, var(--accent) 78%, black 22%) 100%
    );
    color: #0c1a12;
    box-shadow:
      0 0 0 3px var(--background),
      0 0 0 4px color-mix(in srgb, var(--accent) 45%, transparent),
      0 12px 32px color-mix(in srgb, var(--accent) 28%, transparent);
    font-family: var(--font-cn);
    font-size: 56px;
    font-weight: 700;
    line-height: 1;
    user-select: none;
  }
  :global(html[data-theme="dark"]) .home-about-avatar {
    color: #051409;
    box-shadow:
      0 0 0 3px var(--background),
      0 0 0 4px color-mix(in srgb, var(--accent) 55%, transparent),
      0 12px 36px color-mix(in srgb, var(--accent) 24%, transparent);
  }
  .home-about-avatar span {
    transform: translateY(-3px);
  }

  .home-about-meta {
    flex: 1;
    min-width: 0;
  }
  .home-about-handle {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.16em;
    margin-bottom: 8px;
  }
  .home-about-motto {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.005em;
    margin: 0 0 14px;
    color: var(--foreground);
  }
  @media (min-width: 640px) {
    .home-about-motto {
      font-size: 26px;
    }
  }
  .home-about-dot {
    color: var(--accent);
    margin: 0 0.4em;
    font-weight: 400;
  }

  .home-about-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .home-about-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 11px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--foreground);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 11.5px;
    transition:
      border-color 0.12s,
      color 0.12s,
      background 0.12s;
  }
  .home-about-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
