---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
---

<Layout title={`Tag: ${tagName} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout pt-7 pb-4">
    <div
      class="font-mono text-[12.5px]"
      style="color: color-mix(in srgb, var(--foreground) 70%, transparent);"
    >
      <span class="term-prompt">han@ikun126</span><span
        style="color: var(--muted);">:~$</span
      > grep -l '#{tag}' ./posts/*.md
    </div>
    <h2 class="mt-3 mb-1 term-cn text-[28px] font-bold">
      <span style="color: var(--muted);" class="mr-2 font-mono text-[18px]"
        >tag:</span
      >
      <span transition:name={tag} style="color: var(--accent);">#{tagName}</span
      >
    </h2>
    <p class="mt-1 mb-4 font-mono text-[12px]" style="color: var(--muted);">
      {page.total} 篇 · page {page.currentPage} / {page.lastPage}
    </p>

    <ul class="m-0 list-none p-0">
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
