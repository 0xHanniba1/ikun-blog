---
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

if (!SITE.showArchives) {
  return Astro.redirect("/404");
}

const posts = await getCollection("blog", ({ data }) => !data.draft);

type MonthCell = { count: number; posts: typeof posts };
type YearGroup = {
  year: number;
  months: Record<string, MonthCell>;
  total: number;
};

const grouped: Record<number, YearGroup> = {};
for (const p of posts) {
  const d = dayjs(p.data.pubDatetime).tz(SITE.timezone);
  const y = d.year();
  const m = String(d.month() + 1).padStart(2, "0");
  if (!grouped[y]) grouped[y] = { year: y, months: {}, total: 0 };
  if (!grouped[y].months[m]) grouped[y].months[m] = { count: 0, posts: [] };
  grouped[y].months[m].count += 1;
  grouped[y].months[m].posts.push(p);
  grouped[y].total += 1;
}

const years = Object.values(grouped).sort((a, b) => b.year - a.year);
---

<Layout title={`Archives | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout pt-7 pb-10">
    <div
      class="font-mono text-[12.5px]"
      style="color: color-mix(in srgb, var(--foreground) 70%, transparent);"
    >
      <span class="term-prompt">han@ikun126</span><span
        style="color: var(--muted);">:~$</span
      > find ./posts -name "*.md" | sort -r
    </div>
    <h2 class="mt-3 mb-6 term-cn text-[28px] font-bold">归档</h2>

    {
      years.map(yr => (
        <div class="mb-8">
          <div class="mb-3 flex items-baseline gap-3 font-mono">
            <span class="text-[24px] font-bold">{yr.year}</span>
            <span
              class="h-px flex-1"
              style="border-top: 1px dashed var(--border);"
            />
            <span class="text-[11px]" style="color: var(--muted);">
              {yr.total} posts
            </span>
          </div>
          <div class="mb-2 grid grid-cols-12 gap-1.5">
            {Array.from({ length: 12 }).map((_, i) => {
              const m = String(i + 1).padStart(2, "0");
              const cell = yr.months[m];
              const c = cell?.count ?? 0;
              const op = c === 0 ? 0.08 : 0.25 + Math.min(c / 6, 0.75);
              return (
                <div
                  class="relative aspect-square rounded-[2px]"
                  style={`background: var(--accent); opacity: ${op}; cursor: ${c ? "default" : "default"};`}
                  title={`${yr.year}-${m}: ${c} posts`}
                >
                  <span
                    class="absolute top-0.5 left-1 font-mono text-[9px]"
                    style="color: #0c0c08; opacity: 0.7;"
                  >
                    {m}
                  </span>
                  {c > 0 && (
                    <span
                      class="absolute right-1 bottom-0.5 font-mono text-[11px] font-semibold"
                      style="color: #0c0c08;"
                    >
                      {c}
                    </span>
                  )}
                </div>
              );
            })}
          </div>

          {/* Per-month list (collapsed by default for compactness) */}
          <ul class="m-0 list-none p-0">
            {Object.entries(yr.months)
              .sort(([a], [b]) => Number(b) - Number(a))
              .map(([month, cell]) => (
                <li class="flex flex-col gap-2 py-2 sm:flex-row sm:gap-4">
                  <span
                    class="pt-1.5 font-mono text-[11px] sm:w-20 sm:text-right sm:text-[12px]"
                    style="color: var(--muted);"
                  >
                    {yr.year}-{month}
                  </span>
                  <ul class="m-0 flex-1 list-none p-0">
                    {cell.posts
                      .sort(
                        (a, b) =>
                          new Date(b.data.pubDatetime).getTime() -
                          new Date(a.data.pubDatetime).getTime()
                      )
                      .map(p => (
                        <li>
                          <a
                            href={getPath(p.id, p.filePath)}
                            class="term-card block px-2 py-1.5 no-underline"
                          >
                            <span
                              class="mr-2 font-mono text-[11px] tabular-nums"
                              style="color: var(--muted);"
                            >
                              {dayjs(p.data.pubDatetime)
                                .tz(SITE.timezone)
                                .format("MM-DD")}
                            </span>
                            <span class="term-card-title term-cn text-[14px]">
                              {p.data.title}
                            </span>
                          </a>
                        </li>
                      ))}
                  </ul>
                </li>
              ))}
          </ul>
        </div>
      ))
    }
  </main>
  <Footer />
</Layout>
