---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header page="error.log" />
  <main
    id="main-content"
    class="flex app-layout flex-1 items-center justify-center pt-7 pb-10"
  >
    <div class="flex w-full max-w-[480px] flex-col items-start gap-3">
      <div class="font-mono text-[12.5px]" style="color: var(--muted);">
        <span class="term-prompt">han@ikun126</span>:~$ cat {Astro.url.pathname}
      </div>
      <div
        class="w-full rounded-sm px-4 py-3 font-mono text-[13px]"
        style="background: var(--surface-2); border-left: 2px solid var(--accent); color: #ff8a80;"
      >
        cat: {Astro.url.pathname}: No such file or directory
      </div>
      <div
        class="mt-3 font-mono text-[120px] leading-none font-bold"
        style="color: var(--accent);"
      >
        404
      </div>
      <p class="m-0 term-cn text-[18px]">页面不存在</p>
      <a href="/" class="term-btn mt-2 no-underline"> ~$ cd / </a>
    </div>
  </main>
  <Footer />
</Layout>
