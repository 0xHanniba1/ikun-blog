---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header page="error.log" />
  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center pt-7 pb-10"
  >
    <div class="flex flex-col items-start gap-3 max-w-[480px] w-full">
      <div
        class="font-mono text-[12.5px]"
        style="color: var(--muted);"
      >
        <span class="term-prompt">han@ikun126</span>:~$ cat {Astro.url.pathname}
      </div>
      <div
        class="font-mono text-[13px] px-4 py-3 w-full rounded-sm"
        style="background: var(--surface-2); border-left: 2px solid var(--accent); color: #ff8a80;"
      >
        cat: {Astro.url.pathname}: No such file or directory
      </div>
      <div class="font-mono text-[120px] font-bold leading-none mt-3"
        style="color: var(--accent);">
        404
      </div>
      <p class="term-cn text-[18px] m-0">页面不存在</p>
      <a
        href="/"
        class="term-btn no-underline mt-2"
      >
        ~$ cd /
      </a>
    </div>
  </main>
  <Footer />
</Layout>
