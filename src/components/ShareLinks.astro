---
import { SHARE_LINKS } from "@/constants";

const URL = Astro.url;
---

{
  SHARE_LINKS.length > 0 && (
    <div class="flex flex-wrap items-center gap-3 font-mono text-[12px]">
      <span style="color: var(--muted);">// share:</span>
      <div class="flex flex-wrap items-center gap-2">
        {SHARE_LINKS.map(social => (
          <a
            href={`${social.href + URL}`}
            class="term-social"
            title={social.linkTitle}
            aria-label={social.linkTitle}
            target="_blank"
            rel="noopener noreferrer"
          >
            <social.icon class="size-3.5 fill-transparent stroke-current stroke-2" />
          </a>
        ))}
      </div>
    </div>
  )
}
