---
// Floating tweaks panel: font scale + accent + theme.
// Settings persist to localStorage and apply via CSS vars / zoom.
---

<button
  type="button"
  id="tweaks-trigger"
  aria-label="Open tweaks"
>
  <span style="color: var(--accent);">~$</span> tweaks --config
</button>

<div
  id="tweaks-panel"
  role="dialog"
  aria-label="Tweaks"
  hidden
>
  <!-- fake terminal title bar -->
  <div class="tw-chrome">
    <div class="tw-dots" aria-hidden="true">
      <span class="mac-dot mac-dot-red"></span>
      <span class="mac-dot mac-dot-yellow"></span>
      <span class="mac-dot mac-dot-green"></span>
    </div>
    <span class="tw-title">~/.config/tweaks.conf</span>
  </div>

  <div class="tw-body">
    <div class="tw-prompt">
      <span style="color: var(--accent);">han@ikun126</span><span
        style="color: var(--muted);">:~$</span
      > vim ~/.config/tweaks.conf
    </div>

    <!-- font_scale -->
    <section class="tw-section">
      <header class="tw-row">
        <span class="tw-label"># font_scale</span>
        <span class="tw-value"
          ><span style="color: var(--accent);" id="tw-fs-out">1.00</span>x</span
        >
      </header>
      <input
        type="range"
        id="tw-fs"
        min="0.85"
        max="1.2"
        step="0.05"
        value="1"
      />
      <div class="tw-scale-labels">
        <span>0.85x</span><span>1.00x</span><span>1.20x</span>
      </div>
    </section>

    <!-- accent_color -->
    <section class="tw-section">
      <header class="tw-row">
        <span class="tw-label"># accent_color</span>
        <span class="tw-value" id="tw-accent-name">"mint"</span>
      </header>
      <div class="tw-accents" id="tw-accents">
        <button type="button" data-accent="#25c47b" data-name="mint">
          <span style="background: #25c47b;"></span>
        </button>
        <button type="button" data-accent="#ff6b35" data-name="amber">
          <span style="background: #ff6b35;"></span>
        </button>
        <button type="button" data-accent="#7a5fff" data-name="iris">
          <span style="background: #7a5fff;"></span>
        </button>
        <button type="button" data-accent="#e84393" data-name="rose">
          <span style="background: #e84393;"></span>
        </button>
        <button type="button" data-accent="#3a8eff" data-name="azure">
          <span style="background: #3a8eff;"></span>
        </button>
        <button type="button" data-accent="#d4a017" data-name="ochre">
          <span style="background: #d4a017;"></span>
        </button>
      </div>
    </section>

    <!-- theme -->
    <section class="tw-section">
      <div class="tw-label" style="margin-bottom: 6px;"># theme</div>
      <div class="tw-themes">
        <button type="button" data-theme="light" id="tw-theme-light">
          <span class="tw-radio">( )</span>
          <span class="tw-theme-name">light</span>
          <span class="tw-theme-hint">paper · #f5f2ea</span>
        </button>
        <button type="button" data-theme="dark" id="tw-theme-dark">
          <span class="tw-radio">( )</span>
          <span class="tw-theme-name">dark</span>
          <span class="tw-theme-hint">console · #15140f</span>
        </button>
      </div>
    </section>

    <!-- footer hint -->
    <footer class="tw-foot">
      <div>
        <span style="color: var(--accent);">:wq</span>&nbsp;<span
          style="font-family: var(--font-cn);">修改自动保存</span
        >
      </div>
      <div>
        <span style="font-family: var(--font-cn);">按</span>
        <kbd>⌘K</kbd> / <kbd>Ctrl K</kbd>
        <span style="font-family: var(--font-cn);">召唤搜索</span>
      </div>
    </footer>
  </div>
</div>

<style is:global>
  /* Trigger button */
  #tweaks-trigger {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 9000;
    padding: 8px 14px;
    background: var(--background);
    color: var(--foreground);
    border: 1px dashed var(--border);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 12px;
    cursor: pointer;
    box-shadow: 0 6px 18px rgba(60, 50, 30, 0.18);
    transition:
      border-color 0.12s,
      background 0.12s;
  }
  html[data-theme="dark"] #tweaks-trigger {
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.55);
  }
  #tweaks-trigger:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--background));
  }

  /* Panel */
  #tweaks-panel[hidden] {
    display: none;
  }
  #tweaks-panel {
    position: fixed;
    right: 16px;
    bottom: 60px;
    z-index: 9000;
    width: 300px;
    background: var(--background);
    color: var(--foreground);
    border: 1px dashed var(--border);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    box-shadow: 0 16px 40px rgba(60, 50, 30, 0.22);
    overflow: hidden;
  }
  html[data-theme="dark"] #tweaks-panel {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
  }
  .tw-chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-bottom: 1px dashed var(--border);
    background: var(--surface-2);
  }
  .tw-dots {
    display: flex;
    gap: 6px;
  }
  .tw-title {
    flex: 1;
    text-align: center;
    font-size: 11px;
    color: var(--muted);
  }
  .tw-body {
    padding: 12px 14px 14px;
  }
  .tw-prompt {
    font-size: 12px;
    margin-bottom: 14px;
    opacity: 0.85;
  }
  .tw-section {
    margin-bottom: 14px;
  }
  .tw-section:last-of-type {
    margin-bottom: 6px;
  }
  .tw-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }
  .tw-label {
    color: var(--muted);
    font-size: 11px;
  }
  .tw-value {
    font-size: 12px;
  }
  #tw-fs {
    width: 100%;
    accent-color: var(--accent);
  }
  .tw-scale-labels {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* Accent swatches */
  #tw-accents {
    display: flex;
    gap: 6px;
  }
  #tw-accents button {
    flex: 1;
    height: 30px;
    padding: 0;
    background: transparent;
    border: 1px dashed var(--border);
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: border-color 0.12s;
  }
  #tw-accents button:hover {
    border-color: var(--foreground);
  }
  #tw-accents button.is-active {
    border-style: solid;
  }
  #tw-accents button > span {
    width: 14px;
    height: 14px;
    border-radius: 1px;
    display: block;
  }
  #tw-accents button.is-active::before {
    content: "▾";
    position: absolute;
    top: -1px;
    left: 3px;
    font-size: 9px;
    font-family: var(--font-mono);
  }

  /* Theme radios */
  .tw-themes {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tw-themes button {
    text-align: left;
    padding: 6px 10px;
    background: transparent;
    color: var(--foreground);
    border: 1px dashed var(--border);
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition:
      border-color 0.12s,
      background 0.12s;
  }
  .tw-themes button:hover {
    border-color: var(--foreground);
  }
  .tw-themes button.is-active {
    border-style: solid;
    border-color: var(--accent);
    background: var(--surface-2);
  }
  .tw-themes button.is-active .tw-radio {
    color: var(--accent);
  }
  .tw-radio {
    width: 22px;
    color: var(--muted);
  }
  .tw-themes button.is-active .tw-radio {
    color: var(--accent);
  }
  .tw-themes button.is-active .tw-radio::before {
    content: "(•)";
  }
  .tw-themes button.is-active .tw-radio {
    font-size: 0;
  }
  .tw-themes button.is-active .tw-radio::before {
    font-size: 12px;
  }
  .tw-theme-name {
    flex: 1;
  }
  .tw-theme-hint {
    font-size: 10px;
    color: var(--muted);
  }

  .tw-foot {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px dashed var(--border);
    font-size: 11px;
    color: var(--muted);
    line-height: 1.7;
  }
  .tw-foot kbd {
    margin: 0 4px;
    padding: 1px 5px;
    border: 1px solid var(--border);
    border-radius: 2px;
    font-size: 10px;
    font-family: var(--font-mono);
  }
</style>

<script>
  type Tweaks = { fs: number; accent: string; accentName: string };

  const KEY = "ikun-tweaks";
  const ACCENTS = [
    { c: "#25c47b", name: "mint" },
    { c: "#ff6b35", name: "amber" },
    { c: "#7a5fff", name: "iris" },
    { c: "#e84393", name: "rose" },
    { c: "#3a8eff", name: "azure" },
    { c: "#d4a017", name: "ochre" },
  ];

  function load(): Tweaks {
    try {
      const raw = localStorage.getItem(KEY);
      if (raw) return { ...defaults(), ...JSON.parse(raw) };
    } catch {}
    return defaults();
  }
  function save(t: Tweaks) {
    try {
      localStorage.setItem(KEY, JSON.stringify(t));
    } catch {}
  }
  function defaults(): Tweaks {
    return { fs: 1, accent: "#25c47b", accentName: "mint" };
  }

  function applyTweaks(t: Tweaks) {
    const root = document.documentElement;
    root.style.setProperty("--accent", t.accent);
    // zoom is widely supported; scales the visible UI without changing layout math.
    const win = document.querySelector<HTMLElement>(".app-window");
    if (win) {
      win.style.setProperty("zoom", String(t.fs));
      // Firefox fallback (older): use CSS transform.
      // (Modern Firefox supports zoom too.)
    }
  }

  // Apply early so first paint matches.
  applyTweaks(load());

  function bind() {
    const trigger = document.getElementById("tweaks-trigger");
    const panel = document.getElementById("tweaks-panel");
    if (!trigger || !panel || (panel as any).__bound) return;
    (panel as any).__bound = true;

    const fs = panel.querySelector<HTMLInputElement>("#tw-fs")!;
    const fsOut = panel.querySelector<HTMLElement>("#tw-fs-out")!;
    const accentName = panel.querySelector<HTMLElement>("#tw-accent-name")!;
    const accentBtns = panel.querySelectorAll<HTMLButtonElement>(
      "#tw-accents button"
    );
    const themeLight = panel.querySelector<HTMLButtonElement>("#tw-theme-light")!;
    const themeDark = panel.querySelector<HTMLButtonElement>("#tw-theme-dark")!;

    const state = load();

    function refresh() {
      fs.value = String(state.fs);
      fsOut.textContent = state.fs.toFixed(2);
      accentName.textContent = `"${state.accentName}"`;
      accentBtns.forEach(b => {
        b.classList.toggle("is-active", b.dataset.accent === state.accent);
      });
      const theme =
        document.documentElement.getAttribute("data-theme") || "light";
      themeLight.classList.toggle("is-active", theme === "light");
      themeDark.classList.toggle("is-active", theme === "dark");
      applyTweaks(state);
    }
    refresh();

    trigger.addEventListener("click", () => {
      panel.hidden = !panel.hidden;
      if (!panel.hidden) refresh();
    });

    // close panel on outside click
    document.addEventListener("click", e => {
      if (panel.hidden) return;
      const t = e.target as Node;
      if (panel.contains(t) || trigger.contains(t)) return;
      panel.hidden = true;
    });

    fs.addEventListener("input", () => {
      state.fs = parseFloat(fs.value);
      fsOut.textContent = state.fs.toFixed(2);
      save(state);
      applyTweaks(state);
    });

    accentBtns.forEach(b => {
      b.addEventListener("click", () => {
        state.accent = b.dataset.accent!;
        state.accentName = b.dataset.name!;
        save(state);
        refresh();
      });
    });

    themeLight.addEventListener("click", () => {
      document.documentElement.setAttribute("data-theme", "light");
      try {
        localStorage.setItem("theme", "light");
      } catch {}
      refresh();
    });
    themeDark.addEventListener("click", () => {
      document.documentElement.setAttribute("data-theme", "dark");
      try {
        localStorage.setItem("theme", "dark");
      } catch {}
      refresh();
    });
  }

  bind();
  document.addEventListener("astro:page-load", () => {
    // re-apply on view-transition swaps so settings stay sticky
    applyTweaks(load());
    bind();
  });
</script>
