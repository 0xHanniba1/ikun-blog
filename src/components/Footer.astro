---
import type { HTMLAttributes } from "astro/types";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={[{ "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="flex items-center justify-between py-3.5 px-4 sm:px-5 text-[12px]"
    style="color: var(--muted); border-top: 1px dashed var(--border);"
  >
    <span>// © {currentYear} 韩老魔. MIT-ish.</span>
    <span>~$ <span style="color: var(--accent);">exit</span></span>
  </div>
</footer>
