---
type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "term-tag inline-flex items-center no-underline",
      size === "lg" ? "px-2 py-0.5 text-[12px]" : "text-[11px]",
    ]}
    style="color: inherit;"
  >
    #{tagName}
  </a>
</li>
