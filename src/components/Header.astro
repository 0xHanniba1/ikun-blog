---
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconBrandX from "@/assets/icons/IconBrandX.svg";
import IconRss from "@/assets/icons/IconRss.svg";

type Props = {
  page?: string; // window-chrome subtitle, e.g. "home", "posts", "hello-world.md"
};

const { pathname } = Astro.url;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const navItems = [
  { key: "home", label: "~", href: "/" },
  { key: "posts", label: "/posts", href: "/posts/" },
  { key: "tags", label: "/tags", href: "/tags/" },
  ...(SITE.showArchives
    ? [{ key: "archive", label: "/archive", href: "/archives/" }]
    : []),
  { key: "about", label: "/about", href: "/about/" },
];

function activeKey(p: string): string {
  if (p === "/" || p === "") return "home";
  if (p.startsWith("/posts")) return "posts";
  if (p.startsWith("/tags")) return "tags";
  if (p.startsWith("/archives")) return "archive";
  if (p.startsWith("/about")) return "about";
  if (p.startsWith("/search")) return "posts";
  return "";
}

const active = activeKey(currentPath);

const host = (() => {
  try {
    return SITE.website.replace(/^https?:\/\//, "").replace(/\/$/, "");
  } catch {
    return "ikun126.com";
  }
})();

const page =
  Astro.props.page ??
  (active === "home"
    ? "home"
    : active === "posts"
      ? "posts"
      : active === "tags"
        ? "tags"
        : active === "archive"
          ? "archive"
          : active === "about"
            ? "about.md"
            : "shell");

// Map social name -> icon component
const ICON_BY_NAME: Record<string, any> = {
  GitHub: IconGitHub,
  X: IconBrandX,
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<!-- Window chrome (mac traffic lights + zsh title bar) -->
<div
  class="flex items-center gap-3 py-2.5 px-4 sm:px-5"
  style="background: var(--surface); border-bottom: 1px solid var(--border);"
>
    <div class="mac-dots flex gap-2" aria-hidden="true">
      <span class="mac-dot mac-dot-red"></span>
      <span class="mac-dot mac-dot-yellow"></span>
      <span class="mac-dot mac-dot-green"></span>
    </div>
    <div
      class="flex-1 text-center text-[11px] truncate"
      style="color: var(--muted);"
    >
      ~/{host} — {page} — zsh
    </div>
    <button
      id="theme-btn"
      class="text-[11px] cursor-pointer hover:text-accent transition-colors"
      style="color: var(--muted);"
      title="Toggle light / dark"
      aria-label="auto"
      aria-live="polite"
    >
      <span class="theme-light-label">[◑ light]</span>
      <span class="theme-dark-label">[◐ dark]</span>
    </button>
</div>

<!-- Terminal-style nav -->
<header>
  <nav
    id="nav-menu"
    class="flex flex-wrap items-center gap-x-5 gap-y-2 py-3.5 px-4 sm:px-5 text-[13px]"
    style="border-bottom: 1px dashed var(--border);"
  >
    <a
      href="/"
      class="font-semibold whitespace-nowrap"
      style="color: var(--accent);"
    >
      ~$ <span class="term-cn" style="color: var(--foreground);"
        >{SITE.title}</span
      >
    </a>
    <span style="color: var(--muted);" class="hidden sm:inline">|</span>
    <span style="color: var(--muted);" class="hidden md:inline">nav$</span>
    {
      navItems.map(item => {
        const isActive = active === item.key;
        return (
          <a
            href={item.href}
            class:list={["whitespace-nowrap transition-colors hover:text-accent"]}
            style={
              isActive
                ? "color: var(--accent); font-weight: 600;"
                : "color: var(--muted);"
            }
          >
            {isActive ? "> " : "  "}
            {item.label}
          </a>
        );
      })
    }

    <span class="ms-auto flex items-center gap-2">
      <button
        type="button"
        id="cmdk-trigger"
        class="term-searchbox"
        title="Search posts (⌘K)"
        aria-label="Search posts"
      >
        <svg
          width="11"
          height="11"
          viewBox="0 0 16 16"
          aria-hidden="true"
          style="flex-shrink: 0; opacity: 0.7;"
        >
          <circle
            cx="7"
            cy="7"
            r="5"
            stroke="currentColor"
            stroke-width="1.4"
            fill="none"></circle>
          <path
            d="M11 11l3.5 3.5"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"></path>
        </svg>
        <span style="opacity: 0.6; flex: 1; text-align: left;">search posts...</span>
        <kbd
          class="hidden sm:inline-block"
          style="font-size: 9.5px; padding: 1px 5px; border: 1px solid color-mix(in srgb, var(--foreground) 30%, transparent); border-radius: 2px; opacity: 0.7; font-family: var(--font-mono);"
          >⌘K</kbd
        >
      </button>
      {
        SOCIALS.map(s => {
          const Icon = ICON_BY_NAME[s.name];
          return (
            <a
              href={s.href}
              class="term-social"
              title={s.linkTitle}
              aria-label={s.linkTitle}
              target="_blank"
              rel="noopener noreferrer"
            >
              {Icon && (
                <Icon class="size-3.5 fill-transparent stroke-current stroke-2" />
              )}
            </a>
          );
        })
      }
      <a
        href="/rss.xml"
        class="term-social"
        title="RSS Feed"
        aria-label="RSS Feed"
      >
        <IconRss class="size-3.5 fill-transparent stroke-current stroke-2" />
      </a>
    </span>
  </nav>
</header>

<style is:global>
  /* Light theme: show light label, hide dark; dark theme inverts. */
  html[data-theme="light"] #theme-btn .theme-dark-label,
  html:not([data-theme="dark"]) #theme-btn .theme-dark-label {
    display: none;
  }
  html[data-theme="dark"] #theme-btn .theme-light-label {
    display: none;
  }
</style>

<script>
  // ── ⌘K trigger button → open command palette ──────────────
  function bindCmdkTrigger() {
    const btn = document.getElementById("cmdk-trigger");
    if (!btn || btn.dataset.bound === "1") return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("open-cmdk"));
    });
  }
  bindCmdkTrigger();
  document.addEventListener("astro:page-load", bindCmdkTrigger);

  // ── Theme toggle: rebind on every page-load (view-transition) ───
  function bindThemeBtn() {
    const btn = document.getElementById("theme-btn");
    if (!btn || btn.dataset.bound === "1") return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", () => {
      const html = document.documentElement;
      const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch {}
      btn.setAttribute("aria-label", next);
      // Sync <meta name="theme-color"> to current bg.
      const bg = window.getComputedStyle(document.body).backgroundColor;
      document
        .querySelector('meta[name="theme-color"]')
        ?.setAttribute("content", bg);
    });
  }
  bindThemeBtn();
  document.addEventListener("astro:page-load", bindThemeBtn);
</script>
