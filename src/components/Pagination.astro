---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";

type Props = {
  page: Page<CollectionEntry<"blog">>;
};

const { page } = Astro.props;

const total = page.lastPage;
const cur = page.currentPage;
const start = (cur - 1) * page.size + 1;
const end = Math.min(cur * page.size, page.total);
---

{
  page.lastPage > 1 && (
    <nav
      class="flex app-layout flex-wrap items-center gap-2 py-5 text-[12px]"
      style="border-top: 1px dashed var(--border); color: var(--muted);"
      role="navigation"
      aria-label="Pagination Navigation"
    >
      <span>
        page {cur} / {total} · {start}–{end} of {page.total}
      </span>
      <span class="flex-1" />
      <a
        href={page.url.prev ?? "#"}
        class:list={[
          "term-btn no-underline",
          { "pointer-events-none opacity-40": !page.url.prev },
        ]}
        aria-disabled={!page.url.prev}
        aria-label="Previous page"
      >
        ← prev
      </a>
      {Array.from({ length: total }).map((_, i) => {
        const n = i + 1;
        const href = n === 1 ? "/posts/" : `/posts/${n}/`;
        return (
          <a
            href={href}
            class:list={["term-btn no-underline", { "is-active": n === cur }]}
            style="min-width: 30px; justify-content: center;"
            aria-current={n === cur ? "page" : undefined}
          >
            {n}
          </a>
        );
      })}
      <a
        href={page.url.next ?? "#"}
        class:list={[
          "term-btn no-underline",
          { "pointer-events-none opacity-40": !page.url.next },
        ]}
        aria-disabled={!page.url.next}
        aria-label="Next page"
      >
        next →
      </a>
    </nav>
  )
}
